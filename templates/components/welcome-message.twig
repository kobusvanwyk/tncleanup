<div class="container welcome-message" id="welcome-message">
    <div class="row">
        <div>
            <h1 class="welcome-message">
                Get More <span class="yellow-highlight message">5-Star Reviews</span>
            </h1>
            <h2 class="welcome-message-sub small">Our <strong>email signature widget</strong> gets you more 5-star
                reviews <strong>guaranteed.</strong>
            </h2>
        </div>
    </div>
    <div class="row">
        <div>
            <a class="btn btn-pink btn-lg" href="https://app.trustninja.io/signup">
                Get more 5-star reviews
            </a>
        </div>
        <div>
            <span class="cancel-message">Cancel Any Time • No Credit Card Required</span>
        </div>
        <div class="tn-slider" id="tn-slider" style="max-width: 788px; margin: 45px auto 0;">
            <div class="slider-container">
                <ul class="control" id="custom-control">
                    <li class="prev">
                        <i class="fa fa-angle-left fa-2x"></i>
                    </li>
                    <li class="next">
                        <i class="fa fa-angle-right fa-2x"></i>
                    </li>
                </ul>
                <div class="tn-slides">
                    <img src="/images/review-logo-trustpilot.svg"
                         alt="Trustpilot Reviews Logo">
                    <img src="/images/review-logo-yelp.svg"
                         alt="Yelp Reviews Logo">
                    <img src="/images/review-logo-tripadvisor.svg"
                         alt="Tripadvisor Reviews Logo">
                    <img src="/images/review-logo-facebook.svg"
                         alt="Facebook Reviews Logo">
                    <img src="/images/review-logo-google.svg"
                         alt="Google Reviews Logo">
                </div>
            </div>
        </div>

        <script>
            var slider = tns({
                container: '.tn-slides',
                controlsPosition: 'bottom',
                navPosition: 'bottom',
                mouseDrag: true,
                autoplay: true,
                autoplayButtonOutput: false,
                controlsContainer: '#custom-control',
                items: 1,
                responsive: {
                    600: {
                        gutter: 20,
                        items: 2
                    },
                    700: {
                        items: 3,
                        gutter: 30
                    },
                    900: {
                        items: 5,
                        gutter: 40
                    }
                }
            });
        </script>
    </div>
</div>

