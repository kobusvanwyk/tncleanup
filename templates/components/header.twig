                     src="/images/tn-logo.svg">
            </a>
            <div>
                <button class="navbar-toggler px-0 border-0" type="button" data-bs-toggle="offcanvas"
                        data-bs-target="#offcanvasMenu" aria-controls="offcanvasMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasMenu"
                     aria-labelledby="offcanvasMenuLabel">
                    <div class="offcanvas-header">
                        <h5 class="offcanvas-title" id="offcanvasMenuLabel"><img class="site-logo"
                                                                                 alt="TrustNinja Logo"
                                                                                 src="/images/tn-logo.svg">
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                    </div>
                    <div class="offcanvas-body">
                        <div>
                            <ul class="navbar-nav">
                                <li class="nav-item">
                                    <a class="nav-link" href="/#index">Home</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/agency">Agency</a>
                                </li>

                                <li class="icon-nav nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="/review-management-apps" id="featuresDropdown"
                                       role="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                        Review Management Apps
                                    </a>
                                    <div class="icon-nav-dropdown dropdown-menu pb-0">
                                        <a href="/review-management-apps#email-signature-widget"
                                           class="icon-nav-link dropdown-link">
                                            <div>
                                                <div class="text-heading" style="font-size: 18px; font-weight: 500;">
                                                    Email Signature Widget
                                                </div>
                                            </div>
                                        </a>
                                        <a href="/review-management-apps#qr-code-app" class="icon-nav-link dropdown-link">
                                            <div>
                                                <div class="text-heading" style="font-size: 18px; font-weight: 500;">
                                                    QR Code App
                                                </div>
                                            </div>
                                        </a>
                                        <a href="/review-management-apps#social-media-automation"
                                           class="icon-nav-link dropdown-link">
                                            <div>
                                                <div class="text-heading" style="font-size: 18px; font-weight: 500;">
                                                    Social Media Automation
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                </li>

                                <li class="icon-nav nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="featuresDropdown" role="button"
                                       data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                        Pricing
                                    </a>
                                    <div class="icon-nav-dropdown dropdown-menu pb-0">
                                        <a href="/agency#pricing-plans" class="icon-nav-link dropdown-link">
                                            <div>
                                                <div class="text-heading" style="font-size: 18px; font-weight: 500;">
                                                    White-Label Pricing
                                                </div>
                                            </div>
                                        </a>
                                        <a href="/agency#pricing-tiers" class="icon-nav-link dropdown-link">
                                            <div>
                                                <div class="text-heading" style="font-size: 18px; font-weight: 500;">
                                                    Business Owners
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/contact-us">Contact</a>
                                </li>
                                <li class="nav-item me-4">
                                    <a class="nav-link" href="https://app.trustninja.io/signin">Login</a>
                                </li>
                                <li class="nav-item d-lg-inline-block me-0 mt-3 mt-md-0">
                                    <a class="btn btn-pink btn-nav" href="https://app.trustninja.io/signup">Get
                                        started
                                        free</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <script>
        // Converts Bootstrap Dropdown to hoverable
        $(document).ready(function () {
            const iconNav = $('.icon-nav');
            const iconNavDropdown = $('.icon-nav-dropdown');
            const iconNavLink = $('.icon-nav-link');
            const desktopWidth = 992;

            function toggleDropdown() {
                if ($(window).width() >= desktopWidth) {
                    iconNav.hover(function () {
                        $(this).addClass('show');
                        $(this).find(iconNavDropdown).fadeIn(200);
                    }, function () {
                        $(this).removeClass('show');
                        $(this).find(iconNavDropdown).fadeOut(200);
                    });

                    // On desktop, override the dropdown toggle click to navigate instead
                    iconNav.find('.nav-link[href]').on('click.desktopNav', function (e) {
                        const href = $(this).attr('href');
                        if (href && href !== '#') {
                            e.preventDefault();
                            e.stopPropagation();
                            window.location.href = href;
                        }
                    });

                    iconNavLink.click(function () {
                        $(this).closest(iconNav).removeClass('show');
                        $(this).closest(iconNavDropdown).fadeOut(200);
                    });
                } else {
                    iconNav.off('mouseenter mouseleave');
                    iconNav.find('.nav-link').off('click.desktopNav'); // Clean up desktop handler
                    iconNav.removeClass('show');
                    iconNavDropdown.css('display', '');

                    iconNavLink.click(function () {
                        $(this).closest(iconNav).removeClass('show');
                        $(this).closest(iconNavDropdown).fadeOut(200);
                    });
                }
            }

            toggleDropdown();
            $(window).resize(toggleDropdown);

            // Closes off canvas menu when link is clicked
            const offcanvasElement = document.getElementById('offcanvasMenu');
            const offcanvasInstance = new bootstrap.Offcanvas(offcanvasElement);

            $('#offcanvasMenu .icon-nav-link').on('click', function () {
                offcanvasInstance.hide();
                const dropdownParent = $(this).closest('.dropdown');
                if (dropdownParent.length) {
                    const dropdownToggle = dropdownParent.find('.dropdown-toggle');
                    if (dropdownToggle.length) {
                        const dropdownMenu = new bootstrap.Dropdown(dropdownToggle[0]);
                        dropdownMenu.hide();
                    }
                }
            });
        });
    </script>
</header>



