    <script type="application/ld+json" src="/schema/website.txt"></script>

    {# Tracking Scripts #}
    {# Meta #}
    {% include "code-snippets/meta-tracking-pixel.twig" %}

    {# Google #}
    {% include "code-snippets/google-tracking-script.twig" %}

    {# PostHog #}
    {% include "code-snippets/posthog-tracking-script.twig" %}

    <style>
        .popular-tag.popular-tag--agency {
            display: none;
        }

        .agency-pricing-card.agency-pricing-card--popular .popular-tag.popular-tag--agency {
            display: block;
        }

        #singleCouponBundleOption {
            display: block;
        }

        @media (min-width: 768px) {
            #singleCouponBundleOption {
                display: none;
            }
        }
