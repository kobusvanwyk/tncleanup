        <path d="M0 0h99.06C77.33-.02 57.75 13.13 49.53 33.25 41.3 13.14 21.73 0 0 0"
              style="stroke-width:0; fill: #F5F6F8;"/>
    </svg>
</div>
<section class="section section--white overflow-hidden">
    <div class="container" style="max-width: 1060px;">
        <h2 class="rms-pricing-table-heading mb-4"><strong>Benefits of Using Our White Label Software:</strong></h2>
        <ul class="rms-bullet-list">
            <li class="mb-3"><strong>Seamless integration:</strong> Clients signing up with your domain URL will
                automatically be part of your
                ecosystem and have your branding. All system emails will be sent from your own domain.
            </li>
            <li class="mb-3"><strong>Comprehensive support:</strong> We provide email support to you and your clients
                with a generic email address.
            </li>
            <li class="mb-3"><strong>Flexible pricing:</strong> Unused codes <strong>don't expire</strong>, and you can
                transfer codes from cancelled accounts to new accounts <strong>with no time limits</strong> or
                restrictions.
            </li>
            <li class="mb-3"><strong>Granular subscription control:</strong> You as the Agency Owner can quickly & easly
                increase/decrease the subscription levels of your clients in order to restrict the number of staff
                members and features they have access to.
            </li>
            <li class="mb-3"><strong>Easy account management:</strong> As the agency owner, you can easily switch
                between different clients' accounts
                using the Super Admin dropdown. You can also add yourself to clients' accounts to receive notifications.
            </li>
            <li class="mb-3"><strong>Training Videos:</strong> Non-branded training videos are provided in the
                Dashboard.
            </li>
        </ul>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const selectElement = document.getElementById('codeSelect');
        const accountCounts = document.querySelectorAll('.staff-member-account--counts');

        // Function to show/hide elements based on selection
        function updateDisplay(selectedValue) {
            // Hide all <p> and <h2> elements

            document.querySelectorAll('.agency-bundle-name').forEach(function(p) {
                p.style.display = 'none';
            });
            document.querySelectorAll('.actual-price').forEach(function(h2) {
                h2.style.display = 'none';
            });
            document.querySelectorAll('.agency-bundle-name--free').forEach(function(p) {
                p.style.display = 'block';
            });
            document.querySelectorAll('.actual-price--free').forEach(function(p) {
                p.style.display = 'block';
            });

            // Hide all account counts
            accountCounts.forEach(function(p) {
                p.style.display = 'none';
            });

            // Show the corresponding <p> and <h2> based on the selected option
            const selectedP = document.getElementById('bundle_name_' + selectedValue);
            const selectedH2 = document.getElementById('bundle_price_' + selectedValue);
            if (selectedP && selectedH2) {
                selectedP.style.display = 'block';
                selectedH2.style.display = 'block';
            }

            // Show the corresponding account count based on the index of the selected option
            const selectedIndex = selectElement.selectedIndex;
            if (accountCounts[selectedIndex]) {
                accountCounts[selectedIndex].style.display = 'inline-block';
            }
        }

        // Listen to change event on select element
        selectElement.addEventListener('change', function() {
            updateDisplay(this.value);
        });

        // Trigger change event on page load for the first selected option
        updateDisplay(selectElement.value);


        // Initialize the slider (assuming you are using a slider library like 'tiny-slider')
        var slider = tns({
            container: '.rms-slider',
            controlsPosition: 'bottom',
            navPosition: 'bottom',
            mouseDrag: true,
            autoplay: true,
            autoplayButtonOutput: false,
            controlsContainer: '#custom-control',
            items: 1,
            responsive: {
                600: {
                    gutter: 20,
                    items: 2
                },
                700: {
                    items: 3,
                    gutter: 30
                },
                900: {
                    items: 5,
                    gutter: 40
                }
            }
        });

        // Bootstrap popover initialization
        const popoverTriggerList = document.querySelectorAll('[data-bs-toggle="popover"]');
        popoverTriggerList.forEach(popoverTriggerEl => new bootstrap.Popover(popoverTriggerEl));

        // Bootstrap popover for dismissable popover
        const popoverDismissList = document.querySelectorAll('.popover-dismiss');
        popoverDismissList.forEach(popoverDismissEl => new bootstrap.Popover(popoverDismissEl, {
            trigger: 'focus'
        }));

        // Bootstrap tooltip initialization
        const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
        tooltipTriggerList.forEach(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl));
    });
</script>
