<body class="rms-agency">
<header class="rms-landing-header">
    {% set pageName = 'MarketingAgency-ltd-meta' %}
    {% include "components/header.twig" %}
</header>
<section class="rms-agency-hero rms-agency-hero--ltd overflow-hidden"
         style="background-image: url(https://assets.ratemyservice.io/images/rms-landing-background-gradient.webp);">
    <div class="container position-relative z-1">
        <div class="rms-agency-hero__content">
            <div class="rms-agency-hero__text">
                <h1 class="text-white"><strong>Customer Review Management Software</strong></h1>
                <h2 class="text-white"><strong>
                        Boost your clients' online reviews with RateMyService</strong></h2>
                <h3 class="text-white">
                    <strong>White-Label or CNAME review software for <span class="highlight highlight--agency"
                                                                               style="background-image: url(https://assets.ratemyservice.io/images/rms-agency-bundles-highlight.svg);">Agencies</span></strong>
                </h3>
                <div class="rms-agency-hero__cta-buttons">
                    <a class="btn buy-bundle-btn buy-bundle-btn--pink d-block"
                       href="#intro-pic">
                        How it works
                    </a>
                </div>
            </div>
            <div class="rms-agency-ltd-image__container">
                <img class="rms-agency-ltd-image"
                     src="/images/rms-agency-ltd-image.webp"
                     alt="An illustration of characters holding stars">
            </div>
        </div>
    </div>
    <img class="section-split section-split--wave"
         src="/images/rms-section-split-wave.svg"
         alt="A wave pattern that splits two sections">

</section>

<section class="section section--gray overflow-hidden" style="padding-top: 0;">
    <div id="rms-slider" style="max-width: 788px; margin: auto auto 80px auto;">
        <div class="slider-container">
            <ul class="control" id="custom-control">
                <li class="prev">
                    <i class="fa fa-angle-left fa-2x"></i>
                </li>
                <li class="next">
                    <i class="fa fa-angle-right fa-2x"></i>
                </li>
            </ul>
            <div class="rms-slider" style="display: flex;">
                <img src="https://assets.ratemyservice.io/images/review-logo-trustpilot.svg"
                     alt="Trustpilot Reviews Logo">
                <img src="https://assets.ratemyservice.io/images/review-logo-yelp.svg"
                     alt="Yelp Reviews Logo">
                <img src="https://assets.ratemyservice.io/images/review-logo-tripadvisor.svg"
                     alt="Tripadvisor Reviews Logo">
                <img src="https://assets.ratemyservice.io/images/review-logo-facebook.svg"
                     alt="Facebook Reviews Logo">
                <img src="https://assets.ratemyservice.io/images/review-logo-google.svg"
                     alt="Google Reviews Logo">
            </div>
        </div>
    </div>
    <h2 class="text-center mb-5">Explore our <strong><span
                    class="yellow-highlight message">flexible pricing plans</span></strong>
        tailored to your needs</h2>
    <div class="container" style="max-width: 880px;">
        {# AGENCY BUNDLES #}
        <h1 class="text-center my-5 fw-bold text-uppercase">White-Label or CNAME review software for <span
                    class="highlight highlight--agency text-white"
                    style="background-image: url(https://assets.ratemyservice.io/images/rms-agency-bundles-highlight.svg); padding-left: 12px; padding-right: 12px; overflow: hidden; border-radius: 8px;">Agencies</span>
        </h1>
        <div id="form" class="payment__form"></div>
        <div id="message"></div>
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="agency-pricing-card card text-center mb-4">
                    <ul class="list-group">
                        <li class="list-group-item"><p class="agency-bundle-name agency-bundle-name--free"><strong
                                        style="font-size: 24px">14 Day Free Trial</strong></p>
                            <h2 class="actual-price actual-price--free">
                                <strong>$0</strong>
                            </h2>
                            <p><strong>No Credit Card Needed</strong></p>
                            <a class="pricing-button-2 pricing-button-2-aligned mx-auto d-block" id="pink-btn" href="https://app.ratemyservice.io/signup" style=" background-color: #fe0056;">Start My Free Trial</a>
                        </li>
                        <li class="list-group-item p-0">
                            <section style="background-color: rgba(35, 49, 76, 0.05); padding: 20px 0;">
                                <div class="container">
                                    <p class="mb-2"><strong>After your 14-day Free Trial</strong></p>
                                    <img class="mw-100" src="/images/30-day-money-back-gaurantee.png">
                                </div>
                            </section>
                        </li>
                        <li class="list-group-item">
                            <h4 class="small-text">Test x1 Subscription for
                            </h4>
                            <p class="staff-member-account" style="color: #FE0056;"><strong>14 Days</strong></p></li>
                    </ul>
                </div>
            </div>
            <div class="col-md-6">
                <div id="pricingCard"
                     class="agency-pricing-card card text-center mb-4"
                     style="position: relative; overflow: hidden;">

                    <ul class="list-group">
                        <li class="list-group-item"><p class="agency-bundle-name" style="font-size: 24px">
                                {% for couponBundle in couponBundles %}
                            <p id="bundle_name_{{ couponBundle.couponBundleId }}" class="agency-bundle-name" style="font-size: 24px; display: none;">
                                <strong><span>{{ couponBundle.couponBundleName }}</span></strong>
                            </p>
                            <h2 id="bundle_price_{{ couponBundle.couponBundleId }}" class="actual-price" style="display: none;">
                                <strong>${{ couponBundle.priceIncl|number_format(2) }}</strong>
                            </h2>
                            {% endfor %}

                            <select id="codeSelect" class="form-select mt-2 mb-3 code-select-dropdown"
                                    aria-label="Agency Unlimited Code Options">
                                {% for couponBundle in couponBundles %}
                                    <option value="{{ couponBundle.couponBundleId }}"
                                            data-price="{{ couponBundle.priceIncl|number_format }}"
                                            data-name="{{ couponBundle.couponBundleName }}"
                                            data-campaign="{{ couponBundle.campaignId }}"
                                            {% if loop.first %} selected {% endif %}>
                                        {{ couponBundle.couponBundleName }}
                                    </option>
                                {% endfor %}
                            </select>
                            <p><strong>One time payment |</strong> No monthly fees</p>
                            <button id="couponBundlesButton"
                                    onclick="showForm('create', '/purchase/coupon-bundle/form?bundleId=' + $('#codeSelect').val() +'&formToken={{ formToken ("/purchase/coupon-bundle") }}&pageUrl={{ '/agency'|url_encode }}&campaignId=' + $('#codeSelect option:selected').attr('data-campaign'));"
                                    class="pricing-button-2 pricing-button-2-aligned mx-auto">
                                <span>Buy Now</span>
                            </button>
                        </li>
                        <li class="list-group-item p-0">
                            <section style="background-color: rgba(35, 49, 76, 0.05); padding: 20px 0;">
                                <div class="container">
                                    <img class="mw-100" src="/images/30-day-money-back-gaurantee-badge.png">
                                </div>
                            </section>
                        </li>
                        <li class="list-group-item">
                            <h4 class="small-text">Additional White-Labeled ENTERPRISE Account Available to
                                <a tabindex="0"
                                   class="agency-fine-print text-dark"
                                   role="button"
                                   data-bs-toggle="popover"
                                   data-bs-trigger="focus"
                                   data-bs-content="** Each WHITE-LABELED ENTERPRISE Account includes it's own CNAME and the ability to create an UNLIMITED number of Staff Member accounts.">Resell</a>:
                            </h4>
                            <div id="accountCounts">
                                <p class="staff-member-account staff-member-account--counts" id="additionalInfoStartupA" style="color: #FE0056; display: none;">
                                    <strong><span>1</span></strong></p>
                                <p class="staff-member-account staff-member-account--counts" id="additionalInfoStartupB" style="color: #FE0056; display: none;">
                                    <strong><span>5</span></strong></p>
                                <p class="staff-member-account staff-member-account--counts" id="additionalInfoStartupC" style="color: #FE0056; display: none;">
                                    <strong><span>10</span></strong></p>
                                <p class="staff-member-account staff-member-account--counts" id="additionalInfoStartupD" style="color: #FE0056; display: none;">
                                    <strong><span>30</span></strong></p>
                                <p class="staff-member-account staff-member-account--counts" id="additionalInfoStartupE" style="color: #FE0056; display: none;">
                                    <strong><span>50</span></strong></p>
                                <p class="staff-member-account staff-member-account--counts" id="additionalInfoStartupF" style="color: #FE0056; display: none;">
                                    <strong><span>UNLIMITED</span></strong></p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-12 col-md-12">
                <div class="card mb-5 inclusive">
                    <p class="agency-bundle-details-heading"><strong style="font-size: 16px">Also included in
                            Agency/White-labeled bundles:</strong></p>
                    <ul class="starter-bundles mb-0">
                        <li><img src="/images/check-icon.svg" alt="alt"
                                 class="feature-check-icon float-start me-2">Entire Agency Ecosystem is WHITE-LABELED
                        </li>
                        <li><img src="/images/check-icon.svg" alt="alt"
                                 class="feature-check-icon float-start me-2">Unique BRANDING AREA for each PRIMARY
                            AGENCY Account
                        </li>
                        <li><img src="/images/check-icon.svg" alt="alt"
                                 class="feature-check-icon float-start me-2">SUPER ADMIN DROPDOWN, with the ability to
                            quickly SWITCH between your Client-Accounts
                        </li>
                    </ul>
                    <p class="agency-bundle-details-heading"><strong style="font-size: 16px">Money Back Gaurantee:</strong></p>
                    <ul class="starter-bundles mb-0">
                        <li><img src="/images/check-icon.svg" alt="alt"
                                 class="feature-check-icon float-start me-2">60 DAY Money-Back Satisfaction GUARANTEE
                        </li>
                        <li><img src="/images/check-icon.svg" alt="alt"
                                 class="feature-check-icon float-start me-2">LIFE-TIME access to RateMyService
                        </li>
                        <li><img src="/images/check-icon.svg" alt="alt"
                                 class="feature-check-icon float-start me-2">Includes all FUTURE ENTERPRISE & AGENCY
                            PLAN UPDATES
                        </li>
                    </ul>

                    <p class="agency-bundle-details-heading"><strong style="font-size: 16px">Additional Benefits:</strong></p>
                    <ul class="starter-bundles mb-0">
                        <li><img src="/images/check-icon.svg" alt="alt"
                                 class="feature-check-icon float-start me-2"><span class="d-inline-block" tabindex="0"
                                                                                   data-bs-toggle="tooltip"
                                                                                   data-bs-title=" Administrators help manage the account and oversee the reviews they have received. Administrators have full access to each single account. Administrators are not to be confused with Staff Members. Administrators of the Master Account will have all the privileges of the primary Administrator of the Master Account.">

  <span>UNLIMITED Administrators for Each Account Included <img
              src="https://assets.ratemyservice.io/images/rms-info-icon.svg"
              class="tooltip-info"></span>
                        </span></li>


                        <li><img src="/images/check-icon.svg" alt="alt"
                                 class="feature-check-icon float-start me-2">Each Staff Member Account can receive
                            UNLIMITED Reviews / Responses
                        </li>
                        <li><img src="/images/check-icon.svg" alt="alt"
                                 class="feature-check-icon float-start me-2">UNLIMITED
                            Email Alerts from Submitted Reviews / Responses
                        </li>
                        <li><img src="/images/check-icon.svg" alt="alt"
                                 class="feature-check-icon float-start me-2">Customizable
                            & Animated Email Signature Widgets, & Call-to-Actions (CTA)
                        </li>
                        <li><img src="/images/check-icon.svg" alt="alt"
                                 class="feature-check-icon float-start me-2">Mobile Friendly Survey Forms
                        </li>
                        <li><img src="/images/check-icon.svg" alt="alt"
                                 class="feature-check-icon float-start me-2"><span class="d-inline-block" tabindex="0"
                                                                                   data-bs-toggle="tooltip"
                                                                                   data-bs-title=" Display your Customer Touchpoints (i.e. Call-to-Action, Survey Forms, & Review Filter) in the Language of your choosing. Feel free to request your Language if it's missing!">
  <span style="white-space: nowrap;">20+ Languages <img
              src="https://assets.ratemyservice.io/images/rms-info-icon.svg"
              class="tooltip-info"></span>
</span></li>
                    </ul>

                </div>
            </div>
        </div>
    </div>





    <section style="background-color:#ffffff; position: relative; padding: 80px 0">
        <div class="rms-section-split rms-section-split--absolute" id="split-svg">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 99.06 33.25">
                <path d="M0 0h99.06C77.33-.02 57.75 13.13 49.53 33.25 41.3 13.14 21.73 0 0 0" style="stroke-width: 0; fill: #f5f6f8;"></path>
            </svg>
