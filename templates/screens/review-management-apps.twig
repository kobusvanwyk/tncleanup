{# Intro to TrustNinja #}
<section id="intro-video"
         style="background-image: url(/images/tn-landing-background-gradient.webp);"
         class="intro-video bg-cover-hero py-5">
    <div class="tn-section-split tn-section-split--absolute split-svg" id="split-svg">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 99.06 33.25">
            <path d="M0 0h99.06C77.33-.02 57.75 13.13 49.53 33.25 41.3 13.14 21.73 0 0 0"
                  style="stroke-width: 0; fill: #ffffff;"></path>
        </svg>
    </div>
    <div class="the-video text-center">
        <img src="/images/tn-play-button-icon.svg"
             alt="Play button that plays a quick intro video to TrustNinja" data-bs-toggle="modal"
             data-bs-target="#videoModal" data-bs-src="/videos/tn-quick-intro-video.mp4"
             style="cursor: pointer;">
        <h2 class="section-heading text-white lh-sm my-3">A quick intro to <br><span class="fs-1">TrustNinja</span>
        </h2>
    </div>
    <img src="/images/tn-section-split-wave-white.svg"
         alt="A wave pattern that splits two sections"
         class="section-split section-split--wave tn-bottom-fold-wave" id="tn-bottom-fold-wave">
</section>

<!-- Video Modal -->
<div class="modal fade" id="videoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body">
                <!-- Responsive wrapper -->
                <div class="ratio ratio-16x9">
                    <video controls="" preload="none" width="100%" style="cursor: pointer;"
                           poster="/images/tn-video-thumbnail.webp"
                           onclick="this.paused ? this.play() : this.pause(); arguments[0].preventDefault();">
                        <source src="/videos/tn-quick-intro-video.webm"
                                type="video/webm">
                        <source src="/videos/tn-quick-intro-video.mp4" type="video/mp4">
                        Your browser does not support this video file.
                    </video>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Initialize the slider (assuming you are using a slider library like 'tiny-slider')
        var slider = tns({
            container: '.tn-slides',
            controlsPosition: 'bottom',
            navPosition: 'bottom',
            mouseDrag: true,
            autoplay: true,
            autoplayButtonOutput: false,
            controlsContainer: '#custom-control',
            items: 1,
            responsive: {
                600: {
                    gutter: 20,
                    items: 2
                },
                700: {
                    items: 3,
                    gutter: 30
                },
                900: {
                    items: 5,
                    gutter: 40
                }
            }
        });

        // Bootstrap popover initialization
        const popoverTriggerList = document.querySelectorAll('[data-bs-toggle="popover"]');
        popoverTriggerList.forEach(popoverTriggerEl => new bootstrap.Popover(popoverTriggerEl));

        // Bootstrap popover for dismissable popover
        const popoverDismissList = document.querySelectorAll('.popover-dismiss');
        popoverDismissList.forEach(popoverDismissEl => new bootstrap.Popover(popoverDismissEl, {
            trigger: 'focus'
        }));

        // Bootstrap tooltip initialization
        const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
        tooltipTriggerList.forEach(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl));
    });

    // Pure JavaScript solution
    document.addEventListener('DOMContentLoaded', () => {
        var videoModal = document.getElementById('videoModal');
        var videoSrc;

        videoModal.addEventListener('show.bs.modal', function (event) {
            // Button that triggered the modal
            var button = event.relatedTarget;
            // Extract info from data-bs-* attributes
            videoSrc = button.getAttribute('data-bs-src');
            // If YouTube, add autoplay to the URL
            videoSrc += "?autoplay=1&modestbranding=1&showinfo=0";
            // Update the modal's video source
            videoModal.querySelector('#video').src = videoSrc;
        });

        videoModal.addEventListener('hide.bs.modal', function (event) {
            // Reset the video source to stop playback
            videoModal.querySelector('#video').src = '';
        });
    });
</script>

<footer>
    {% include "components/footer.twig" with { footerSvgFill: 'white' } %}
</footer>
</body>
</html>