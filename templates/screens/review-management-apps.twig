</section>

{# Email Signature Review Widget #}
<section id="email-signature-widget" style="background-color:#FFFFFF;">
    <div class="container">
        <div class="row d-flex justify-content-center">
            <div class="col-lg-6 col-sm-12 px-4 d-flex flex-column align-items-start justify-content-center">
                <h4 class="yellow-highlight-sub-heading">Email Signature Review Widget</h4>
                <h2 class="section-heading my-3">Turn Every Email Into a Review Opportunity</h2>
                <div class="d-lg-flex d-sm-flex d-block my-3">
                    <div class="me-3">
                        <img src="/images/email-sig-review-widget-icon.svg"
                             alt="">
                    </div>
                    <div class="mt-lg-0 mt-sm-0 mt-3">
                        <p class="mb-0">The Email Signature Review Widget automatically prompts customers to leave
                            reviews through everyday email communication. This passive approach drives consistent review
                            growth without manual follow-ups.</p>
                    </div>
                </div>

                <div class="tn-idea-for-box-grey mt-2">
                    <img src="/images/tn-thumbs-up-five-stars-icon.svg"
                         alt="">
                    <ul class="tn-bullet-list mt-lg-0 mt-sm-0 mt-3 mb-0">
                        <li>Your Client gets more 5-star reviews</li>
                        <li>Your Client Recovers Dropped Balls</li>
                        <li>Your Client can track team performances</li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-6 col-sm-12 px-4 d-flex flex-column align-items-center justify-content-center">
                <img src="/images/email-sig-review-widget.svg"
                     alt="RMS email signature review widget graphic" class="w-100 mt-lg-0 mt-sm-5 mt-4">
            </div>

        </div>

    </div>
</section>

{#    QR Code Review App #}
