# ─────────────────────────────────────────────────────────────────
# TrustNinja — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Mandrill (Mailchimp Transactional) API key
# Used for sending contact form emails
# Get yours at: https://mandrillapp.com
MANDRILL_API_KEY=your-mandrill-api-key-here

# Google reCAPTCHA v3
# Used to protect the contact form from spam
# Get your keys at: https://www.google.com/recaptcha
RECAPTCHA_V3_SITE_KEY=your-recaptcha-site-key-here
RECAPTCHA_V3_SECRET_KEY=your-recaptcha-secret-key-here

# Contact form recipient
# Submissions from the contact page will be sent to this address
CONTACT_US_EMAIL=hello@trustninja.io
